# Copy to app_store_connect.env (gitignored) and fill in.
# Get Issuer ID + confirm Key ID: App Store Connect → Users and Access → Integrations → App Store Connect API
#
# Your key file is named AuthKey_<KEY_ID>.p8 — do not commit it. Typical location after download:
#   macOS: ~/.appstoreconnect/private_keys/AuthKey_<KEY_ID>.p8
#
# Create folder and copy once:
#   mkdir -p ~/.appstoreconnect/private_keys
#   cp ~/Downloads/AuthKey_SWKQYRLMSP.p8 ~/.appstoreconnect/private_keys/

APP_STORE_CONNECT_ISSUER_ID=00000000-0000-0000-0000-000000000000
APP_STORE_CONNECT_KEY_ID=SWKQYRLMSP
